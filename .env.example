# =============================================================================
# Sub2API + Caddy Environment Configuration
# =============================================================================
# 1. Run ./setup.sh  — generates secrets and creates this file as .env
# 2. Edit .env and set your real domain
# 3. docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Domain (REQUIRED)
# Must point to this server's public IP before starting.
# Caddy will automatically obtain a Let's Encrypt certificate via DNS-01.
# -----------------------------------------------------------------------------
DOMAIN=your.domain.com

# -----------------------------------------------------------------------------
# Cloudflare API Token (REQUIRED when Cloudflare proxy is enabled)
# DNS-01 challenge is used instead of HTTP-01 to bypass Cloudflare's proxy.
#
# Create a token at: Cloudflare Dashboard → My Profile → API Tokens
#   Permissions required: Zone / DNS / Edit
#   Zone Resources:      Include / Specific zone / <your domain>
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=            # generated by setup.sh
POSTGRES_DB=sub2api

# -----------------------------------------------------------------------------
# JWT & TOTP (generated by setup.sh — do NOT leave empty in production)
# -----------------------------------------------------------------------------
JWT_SECRET=
TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Admin account
# Leave ADMIN_PASSWORD empty to auto-generate (check `docker compose logs sub2api`)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
