# Build Caddy with Cloudflare DNS plugin for DNS-01 ACME challenge.
# Required when Cloudflare proxy (orange cloud) is enabled — HTTP-01 cannot
# reach the origin server, so certificate issuance must go through DNS.

FROM caddy:2-builder-alpine AS builder
RUN xcaddy build --with github.com/caddy-dns/cloudflare

FROM caddy:2-alpine
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
